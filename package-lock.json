{
  "name": "gym-diary",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "gym-diary",
      "workspaces": [
        "packages/*"
      ],
      "dependencies": {
        "@gym-diary/exercise": "file:./packages/exercise",
        "@gym-diary/strength-score": "file:./packages/strength-score"
      }
    },
    "node_modules/@gym-diary/exercise": {
      "resolved": "packages/exercise",
      "link": true
    },
    "node_modules/@gym-diary/strength-score": {
      "resolved": "packages/strength-score",
      "link": true
    },
    "packages/exercise": {
      "name": "@gym-diary/exercise",
      "version": "1.0.0"
    },
    "packages/strength-score": {
      "name": "@gym-diary/strength-score",
      "version": "1.0.0"
    }
  }
}
